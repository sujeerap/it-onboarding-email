# ─────────────────────────────────────────────────────────
# IT Onboarding Email Server — Environment Variables
# Copy this file to .env and fill in your real values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────

# Server port (Railway sets this automatically)
PORT=3000

# ── Department email accounts (Office 365) ────────────────
# Each department sends from its own mailbox

# Management — Mohammed Al-Raihan
EMAIL_MANAGEMENT=mohammed.alraihan@yourcompany.com
PASS_MANAGEMENT=your_password_here

# IT — Sujeer
EMAIL_IT=it@yourcompany.com
PASS_IT=your_password_here

# HR — Abdullah Al-Salmi
EMAIL_HR=hr@yourcompany.com
PASS_HR=your_password_here

# Access Control — Salem Bin Sawad
EMAIL_ACCESS=access@yourcompany.com
PASS_ACCESS=your_password_here

# POS — Mona
EMAIL_POS=pos@yourcompany.com
PASS_POS=your_password_here

# ── Recipient email addresses ─────────────────────────────
# Used by the app to know where to send notifications
RECIPIENT_MANAGEMENT=mohammed.alraihan@yourcompany.com
RECIPIENT_IT=it@yourcompany.com
RECIPIENT_HR=hr@yourcompany.com
RECIPIENT_ACCESS=access@yourcompany.com
RECIPIENT_POS=pos@yourcompany.com
